### Clerk (required)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...

### Neon Postgres (required for analytics + mailing)
# Provision prod + staging databases via Vercel Marketplace → Neon.
# Use the pooled connection string (recommended for serverless).
DATABASE_URL=postgres://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

### Clerk webhooks (required for user_key + identity sync)
# Clerk Dashboard → Webhooks → POST https://www.flowbalance.app/api/webhooks/clerk
# Subscribe: user.created|updated|deleted, organizationMembership.*, subscriptionItem.*
# CLERK_WEBHOOK_SECRET is the project name; Clerk also accepts CLERK_WEBHOOK_SIGNING_SECRET.
CLERK_WEBHOOK_SECRET=whsec_...

### Internal ops (cron + protected health check)
# Bearer token for GET /api/health/db and future cron routes (Mail-8).
CRON_SECRET=...

### Web base URL (optional)
# Only needed if you ever run in a non-http origin (e.g. bundled Capacitor mode).
NEXT_PUBLIC_WEB_BASE_URL=https://www.flowbalance.app

### Cloudflare R2 (required for private audio streaming)
R2_ACCOUNT_ID=4a1035be915245d0de8e66f94f9ed75e
R2_BUCKET_NAME=flowbalance
R2_ACCESS_KEY_ID=...             # from Cloudflare R2 S3 API token screen
R2_SECRET_ACCESS_KEY=...         # from Cloudflare R2 S3 API token screen
R2_REGION=auto


